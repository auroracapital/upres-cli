{
  "name": "upres-cli",
  "version": "0.1.0",
  "description": "Official CLI + SDK for upres.ai — AI image & video upscaling",
  "type": "module",
  "main": "./dist/client.js",
  "exports": {
    ".": {
      "import": "./dist/client.js",
      "require": "./dist/client.cjs",
      "types": "./dist/client.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "require": "./dist/types.cjs",
      "types": "./dist/types.d.ts"
    }
  },
  "bin": {
    "upres": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "upscaling",
    "cli",
    "real-esrgan",
    "seedvr2",
    "image-processing",
    "video-upscaling",
    "8k",
    "upscaler",
    "ai-tools",
    "image-upscaler",
    "ai-image-upscaler"
  ],
  "author": "upres.ai <support@upres.ai>",
  "license": "MIT",
  "homepage": "https://upres.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/auroracapital/upres-cli"
  },
  "bugs": {
    "url": "https://github.com/auroracapital/upres-cli/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
